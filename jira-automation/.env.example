# JIRA Configuration
# Your JIRA instance URL (e.g., https://your-company.atlassian.net)
JIRA_URL=https://your-company.atlassian.net

# JIRA Personal Access Token (PAT) for authentication
# Generate from: JIRA Settings > Personal Access Tokens
JIRA_PAT_TOKEN=your_jira_pat_token_here

# JIRA Project Key (e.g., SUPPORT, INC, etc.)
JIRA_PROJECT_KEY=SUPPORT

# JQL query to filter tickets in the queue
# Example: project = SUPPORT AND status = "To Do" AND assignee is EMPTY
JIRA_QUEUE_JQL=project = SUPPORT AND status = "To Do" AND assignee is EMPTY

# Mistral AI Configuration
# API key for Mistral AI service
# Get your API key from: https://console.mistral.ai/
MISTRAL_API_KEY=your_mistral_api_key_here

# Slack Configuration
# Slack Bot Token for sending notifications
# Create a Slack app and get the token from: https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here

# Slack Channel ID where notifications will be sent
# Right-click on channel > View channel details > Copy Channel ID
SLACK_CHANNEL_ID=C1234567890

# Logging Configuration
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO